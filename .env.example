# Copy to repo root .env.local (recommended) or place as backend/.env
GEMINI_API_KEY=

# Optional: backend server settings
# HOST=127.0.0.1
# PORT=8000
# RELOAD=true

# Optional: comma-separated origins for CORS (defaults include localhost:3000)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: enable Supabase persistence endpoints
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
